<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light">

    <!-- Toolbar/Header -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary_color"
        app:title="Paramètres"
        app:titleTextColor="@android:color/white"
        app:navigationIcon="@drawable/ic_arrow_back"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Section Sauvegarde et synchronisation -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sauvegarde et synchronisation"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/primary_color"
                android:layout_marginBottom="16dp"/>

            <!-- Sauvegarde locale -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_local_backup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="2dp"
                app:cardCornerRadius="8dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sauvegarde locale"
                            android:textSize="16sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Enregistrer automatiquement"
                            android:textSize="14sp"
                            android:textColor="@color/text_secondary"/>
                    </LinearLayout>

                    <!-- Switch pour activer/désactiver la sauvegarde locale -->
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_local_backup"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        app:trackTint="@color/switch_thumb_selector"
                        app:thumbTint="@color/switch_track_selector"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Google Drive -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_google_drive"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="2dp"
                app:cardCornerRadius="8dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Google Drive"
                            android:textSize="16sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Synchroniser avec le cloud"
                            android:textSize="14sp"
                            android:textColor="@color/text_secondary"/>
                    </LinearLayout>

                    <!-- Switch pour activer/désactiver Google Drive -->
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_google_drive"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false"
                        app:trackTint="@color/switch_thumb_selector"
                        app:thumbTint="@color/switch_track_selector"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Compte connecté -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_account"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="2dp"
                app:cardCornerRadius="8dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Compte connecté"
                            android:textSize="16sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/account_email"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="utilisateur@gmail.com"
                            android:textSize="14sp"
                            android:textColor="@color/text_secondary"/>
                    </LinearLayout>

                    <!-- Indicateur de compte (pas de switch, juste une icône simple) -->
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_account_circle"
                        android:tint="@color/primary_color"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Restaurer depuis Google Drive -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_restore"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="2dp"
                app:cardCornerRadius="8dp"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Restaurer depuis Google Drive"
                            android:textSize="16sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Récupérer les notes sauvegardées"
                            android:textSize="14sp"
                            android:textColor="@color/text_secondary"/>
                    </LinearLayout>

                    <!-- Bouton Restaurer -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_restore"
                        style="@style/Widget.MaterialComponents.Button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Restaurer"
                        android:textSize="12sp"
                        android:padding="4dp"
                        android:backgroundTint="@color/accent_color"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Supprimer toutes les notes -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_delete_all"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="2dp"
                app:cardCornerRadius="8dp"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Supprimer toutes les notes"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/error_color"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Effacer définitivement les données"
                            android:textSize="14sp"
                            android:textColor="@color/text_secondary"/>
                    </LinearLayout>

                    <!-- Bouton Supprimer -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_delete_all"
                        style="@style/Widget.MaterialComponents.Button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Supprimer"
                        android:textSize="12sp"
                        android:padding="4dp"
                        android:backgroundTint="@color/error_color"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Gérer les notes -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_manage_notes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="2dp"
                app:cardCornerRadius="8dp"
                android:layout_marginBottom="24dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gérer les notes"
                            android:textSize="16sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Organiser et trier les notes"
                            android:textSize="14sp"
                            android:textColor="@color/text_secondary"/>
                    </LinearLayout>

                    <!-- Bouton Gérer -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_manage"
                        style="@style/Widget.MaterialComponents.Button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ouvrir"
                        android:textSize="12sp"
                        android:padding="4dp"
                        android:backgroundTint="@color/accent_color"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section Apparence -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Apparence"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/primary_color"
                android:layout_marginBottom="16dp"/>

            <!-- Thème de l'application -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="2dp"
                app:cardCornerRadius="8dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thème de l'application"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>

                    <RadioGroup
                        android:id="@+id/radio_group_theme"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <RadioButton
                            android:id="@+id/radio_light"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Clair"
                            android:checked="true"
                            android:textSize="14sp"
                            android:layout_marginEnd="16dp"/>

                        <RadioButton
                            android:id="@+id/radio_dark"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sombre"
                            android:textSize="14sp"
                            android:layout_marginEnd="16dp"/>

                        <RadioButton
                            android:id="@+id/radio_auto"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Automatique"
                            android:textSize="14sp"/>
                    </RadioGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Bouton Se déconnecter -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_logout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Se déconnecter"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:textColor="@color/error_color"
                app:strokeColor="@color/error_color"
                android:layout_marginTop="16dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>